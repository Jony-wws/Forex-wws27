# Required: password for the single user that logs into the site.
SITE_PASSWORD=change-me

# Required: a long random string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-long-random-string

# Optional: where SQLite is stored. On Fly.io this should point at a
# mounted volume so chat history survives restarts.
DATA_DIR=/data

# Optional: GitHub token used by the "Export to GitHub" feature. Needs
# `contents: write` on whichever repo you target.
GITHUB_TOKEN=

# Optional: default repo for "Export to GitHub" (owner/repo). Can be
# overridden per export from the UI.
GITHUB_DEFAULT_REPO=

# Devin API base URL. Default is fine.
DEVIN_API_BASE=https://api.devin.ai
